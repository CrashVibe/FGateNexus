{
  "name": "fgatenexus",
  "version": "0.5.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "NODE_ENV=production nuxt build",
    "dev": "NODE_ENV=development nuxt dev --inspect",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "format": "oxfmt .",
    "lint": "oxlint --type-aware",
    "lint:fix": "oxlint --fix --type-aware",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun scripts/migrate.ts",
    "build:all": "bun run build && bun run build:mac && bun run build:linux && bun run build:win",
    "build:mac": "bun build --compile --minify --sourcemap --production --target=bun-darwin-arm64 ./entry.ts --outfile ./dist/FGateNexus-mac-arm64 && bun build --compile --minify --sourcemap --production --target=bun-darwin-x64 ./entry.ts --outfile ./dist/FGateNexus-mac-x64",
    "build:linux": "bun build --compile --minify --sourcemap --production --target=bun-linux-arm64 ./entry.ts --outfile ./dist/FGateNexus-linux-arm64 && bun build --compile --minify --sourcemap --production --target=bun-linux-x64 ./entry.ts --outfile ./dist/FGateNexus-linux-x64",
    "build:win": "bun build --compile --minify --sourcemap --production --target=bun-windows-x64 ./entry.ts --outfile ./dist/FGateNexus-win-x64.exe",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@koishijs/plugin-adapter-discord": "^4.6.1",
    "@koishijs/plugin-http": "^0.6.3",
    "@koishijs/plugin-server": "^3.2.9",
    "@mrlingxd/koishi-plugin-adapter-onebot": "^0.2.10",
    "@nuxt/icon": "2.2.1",
    "@nuxt/ui": "^4.7.1",
    "@pinia/nuxt": "^0.11.3",
    "@sentry/nuxt": "^10.53.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/lodash-es": "^4.17.12",
    "@zxcvbn-ts/core": "^3.0.4",
    "@zxcvbn-ts/language-common": "^3.0.4",
    "dayjs": "^1.11.20",
    "drizzle-orm": "^0.45.2",
    "http-status-codes": "^2.3.0",
    "koishi": "^4.18.11",
    "limiter": "^3.0.0",
    "lodash-es": "^4.18.1",
    "lru-cache": "^11.3.6",
    "nanoid": "^5.1.11",
    "nuxt": "^4.4.5",
    "nuxt-auth-utils": "0.5.29",
    "nuxt-qrcode": "^0.4.10",
    "otplib": "^13.4.0",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "puppeteer-core": "^24.43.1",
    "tailwindcss": "^4.3.0",
    "uuid": "^13.0.2",
    "vooks": "^0.2.12",
    "vue": "^3.5.34",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "^1.3.14",
    "better-sqlite3": "^12.10.0",
    "drizzle-kit": "^0.31.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.16.0",
    "sass-embedded": "^1.99.0",
    "typescript": "^5.9.3",
    "ultracite": "7.6.0"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "oxlint . --fix --quiet",
      "oxfmt . --write"
    ]
  },
  "apiVersion": "0.0.3",
  "json-comments": {
    "tips": "请安装 JSONComments 插件为 JSON 文件提供注释功能，详见：https://github.com/zhangfisher/json_comments_extension",
    "package.json": {
      "devDependencies.better-sqlite3": "为了了让 Drizzle ORM 能够在开发环境下正常工作"
    }
  },
  "minimumClientVersion": "0.0.1",
  "patchedDependencies": {
    "nuxt-auth-utils@0.5.29": "patches/nuxt-auth-utils@0.5.29.patch",
    "@koishijs/loader@4.6.11": "patches/@koishijs%2Floader@4.6.11.patch",
    "@satorijs/adapter-discord@4.6.1": "patches/@satorijs%2Fadapter-discord@4.6.1.patch"
  }
}
